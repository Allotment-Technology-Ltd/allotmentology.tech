# Neon Postgres — create a project at https://neon.tech and paste the connection string.
DATABASE_URL="postgresql://USER:PASSWORD@HOST.neon.tech/neondb?sslmode=require"

# Neon Auth — REQUIRED for local dev: Neon Console → your project → Branch → Auth → Configuration.
# Copy the full “Auth URL” (must be a real hostname, not a placeholder).
# Example shape: https://ep-xxx.neonauth.eu-west-2.aws.neon.tech/neondb/auth
# Do not leave a fake URL — DNS errors like ENOTFOUND mean this value was not replaced.
NEON_AUTH_BASE_URL=""

# Optional — Phase 8 AI layer (OpenAI-compatible chat completions)
# AI_PROVIDER="openai-compatible"   # or "restormel-keys"
# AI_API_KEY="sk-..."
# AI_BASE_URL="https://api.openai.com/v1"
# AI_MODEL="gpt-4o-mini"
#
# Optional — Restormel Keys adapter
# RESTORMEL_KEYS_API_KEY="rk_..."
# RESTORMEL_KEYS_BASE_URL="https://api.restormel.dev/v1"
# RESTORMEL_KEYS_MODEL="restormel-writer-v1"
#
# Optional — Gateway API docs portal URL (Zuplo). Default matches the "API portal" link on
# https://restormel.dev/keys/dashboard — override if Restormel publishes a new portal.
# NEXT_PUBLIC_RESTORMEL_KEYS_API_PORTAL_URL="https://restormel-keys-gateway-main-bc13eba.zuplo.site"
